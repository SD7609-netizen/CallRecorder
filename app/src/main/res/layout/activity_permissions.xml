<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="права доступа"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-light" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:text="Для правильной работы Call Recorder необходимо разрешить"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Microphone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface_dark"
                android:padding="16dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Доступ к микрофону для записи звука"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                <ImageView
                    android:id="@+id/ivMic"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_cross_red"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Contacts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface_dark"
                android:padding="16dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Доступ к контактам, чтобы вы могли искать и назначать имена контактов для записи звука"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                <ImageView
                    android:id="@+id/ivContacts"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_cross_red"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Phone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface_dark"
                android:padding="16dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Управление телефонными звонками для точной записи входящих и исходящих звонков"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                <ImageView
                    android:id="@+id/ivPhone"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_cross_red"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Battery -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface_dark"
                android:padding="16dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Игнорируйте оптимизацию батареи, чтобы Call Recorder мог работать в фоновом режиме при выключении экрана"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                <ImageView
                    android:id="@+id/ivBattery"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_cross_red"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Accessibility -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface_dark"
                android:padding="16dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Включите соединитель приложения Call Recorder для записи звонков на Android 10"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                <ImageView
                    android:id="@+id/ivAccessibility"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_cross_red"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Overlay (SYSTEM_ALERT_WINDOW) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface_dark"
                android:padding="16dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Отображение поверх других приложений — для всплывающего запроса сохранения записи"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                <ImageView
                    android:id="@+id/ivOverlay"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_cross_red"
                    android:contentDescription="@null" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/bg_dark">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrant"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Предоставить разрешения"
            android:textSize="15sp"
            app:backgroundTint="@color/accent"
            app:cornerRadius="28dp" />

    </LinearLayout>

</LinearLayout>
